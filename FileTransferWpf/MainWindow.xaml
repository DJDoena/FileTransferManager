<Window x:Class="DoenaSoft.FileTransferManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Transfer Manager (WPF)" Height="500" Width="800">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="159*"/>
            <ColumnDefinition Width="625*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8" Grid.ColumnSpan="2">
            <Button x:Name="AddFolderButton" Content="Add Folder" Width="100" Margin="0,0,8,0" Click="OnAddFolderClick" />
            <Button x:Name="AddFileButton" Content="Add File(s)" Width="100" Margin="0,0,8,0" Click="OnAddFileClick" />
            <Button x:Name="RemoveEntryButton" Content="Remove" Width="80" Margin="0,0,8,0" Click="OnRemoveEntryClick" />
            <Button x:Name="ClearListButton" Content="Clear" Width="80" Margin="0,0,8,0" Click="OnClearListClick" />
            <CheckBox x:Name="WithSubFoldersCheckBox" Content="With Subfolders" VerticalAlignment="Center" Checked="OnWithSubFoldersCheckedChanged" Unchecked="OnWithSubFoldersCheckedChanged" />
        </StackPanel>

        <ListBox x:Name="SourceListBox" Grid.Row="1" Margin="0,0,0,8" DisplayMemberPath="ToString" Grid.ColumnSpan="2" />

        <StackPanel Orientation="Horizontal" Grid.Row="2" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <ProgressBar x:Name="CopyProgressBar" Width="300" Height="20" Margin="0,0,8,0" />
            <Label x:Name="SizeLabel" Content="0 Byte" Width="120" />
            <Label x:Name="RemainingLabel" Content="" Width="260" />
            <Button x:Name="CopyButton" Content="Copy" Width="100" Margin="8,0,0,0" Click="OnCopyClick" />
            <Button x:Name="AbortButton" Content="Abort" Width="80" Margin="8,0,0,0" Click="OnAbortClick" Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Window>